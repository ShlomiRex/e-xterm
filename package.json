{
	"name": "e-xterm",
	"version": "1.0.0",
	"description": "e-xterm is cross-platform electron SSH and SFTP program, which aims to be used for commercial/professional users.",
	"main": "./dist/main.bundle.js",
	"license": "MIT",
	"scripts": {
		"start": "electron ./dist/main.bundle.js",
		"watch:dev": "rimraf dist && cross-env NODE_ENV=development webpack --watch --progress --color",
		"watch:prod": "rimraf dist && cross-env NODE_ENV=production webpack --progress --color",
		"test": "mocha -r ts-node/register -r tsconfig-paths/register \"test/**/*.ts\"",
		"build:win": "electron-builder build --win --x64",
		"build:mac": "electron-builder build --mac --x64"
	},
	"build": {
		"appId": "com.devtography.electron_boilerplate",
		"productName": "Electron+React+TypeScript Boilerplate",
		"directories": {
			"app": "./dist/",
			"output": "./out/"
		},
		"mac": {
			"target": "dmg"
		},
		"win": {
			"target": "nsis",
			"asar": true
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		},
		"buildVersion": "1"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ShlomiRex/e-xterm"
	},
	"author": "Shlomi Domnenko",
	"dependencies": {
		"react": "^17.0.1",
		"react-dom": "^17.0.1",
		"xterm": "^4.13.0",
		"xterm-for-react": "^1.0.4"
	},
	"devDependencies": {
		"@types/mocha": "^8.2.0",
		"@types/react": "^17.0.0",
		"@types/react-dom": "^17.0.0",
		"@typescript-eslint/eslint-plugin": "^4.11.0",
		"@typescript-eslint/parser": "^4.11.0",
		"copy-webpack-plugin": "^7.0.0",
		"cross-env": "^7.0.3",
		"css-loader": "^5.0.1",
		"electron": "^11.1.1",
		"electron-builder": "^22.9.1",
		"eslint": "^7.16.0",
		"file-loader": "^6.2.0",
		"html-webpack-plugin": "^4.5.0",
		"lodash": "^4.17.20",
		"mocha": "^8.2.1",
		"rimraf": "^3.0.2",
		"style-loader": "^2.0.0",
		"ts-loader": "^8.0.12",
		"typescript": "^4.1.3",
		"webpack": "^5.11.0",
		"webpack-cli": "^4.7.2"
	}
}
