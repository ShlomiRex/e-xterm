{
	"compilerOptions": {
	  "allowSyntheticDefaultImports": true,
	  "jsx": "react",
	  "baseUrl": ".",
	  "paths": {
		"_/*": ["src/*"],
		"_public/*": ["public/*"],
		"_main/*": ["src/main/*"],
		"_models/*": ["src/models/*"],
		"_renderer/*": ["src/renderer/*"],
		"_utils/*": ["src/utils/*"]
	  },
	  "module": "commonjs",
	  "moduleResolution": "node",
	  "noImplicitAny": true,
	  "noImplicitThis": true,
	  "strictNullChecks": true,
	  "strict": true,
	  "sourceMap": true,
	  "target": "ES6"
	},
	"exclude": ["node_modules"]
  }
  